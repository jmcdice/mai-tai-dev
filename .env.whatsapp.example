# WhatsApp bridge env — copy to .env.whatsapp and fill in.
# Used by docker-compose.whatsapp.yml (Evolution API) and the mai-tai backend bridge.

# --- Evolution API ---
EVOLUTION_PORT=8190
# A long random string. Protects the Evolution REST API. Generate e.g.:
#   openssl rand -hex 24
EVOLUTION_API_KEY=

# Evolution's own Postgres/Redis (isolated from mai-tai's DB)
EVO_PG_USER=evolution
EVO_PG_PASSWORD=evolution
EVO_PG_DB=evolution

# --- Bridge wiring (Evolution → mai-tai backend) ---
# Where Evolution should POST inbound WhatsApp events. Must be reachable from
# the Evolution container. On the mini, typically the backend's LAN address:
#   http://<backend-host>:8000/api/v1/whatsapp/webhook?secret=<WA_WEBHOOK_SECRET>
WA_WEBHOOK_URL=

# Shared secret the backend uses to verify inbound webhooks really came from
# our Evolution instance. Generate e.g.: openssl rand -hex 24
WA_WEBHOOK_SECRET=

# The Evolution "instance" name the bridge will create/use for this number.
WA_INSTANCE=surf-trip

# Base URL the backend uses to call Evolution's REST API (sendText, etc).
# From the backend container's perspective.
EVOLUTION_BASE_URL=http://maitai-evolution:8080
